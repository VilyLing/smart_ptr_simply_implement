{
    "version": 7,
    "configurePresets": [
        {
            "name": "base",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "generator": "Ninja",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS":"ON"
            }
        },
        {
            "name": "debug",
            "hidden": true,
            "inherits":["base"],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":"Debug"
            }
        },
        {
            "name": "asan",
            "inherits":["debug"],
            "displayName": "使用AddressSanitizer",
            "description": "测试内存泄漏",
            "cacheVariables": {
                "CMAKE_CXX_SANITIZERS":"address"
            }
        },
        {
            "name": "clang-debug",
            "inherits":["asan"],
            "displayName": "Use clang to compile",
            "description": "Linux/MacOs",
            "cacheVariables": {
                "CMAKE_C_COMPILER":"clang",
                "CMAKE_CXX_COMPILER":"clang++"
            }
        },
        {
            "name": "release",
            "hidden": true,
            "inherits":["base"],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":"Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "clang-debug",
            "configurePreset": "clang-debug"
        }
    ],
    "testPresets": [
        {
            "name": "test-asan",
            "configurePreset": "clang-debug",
            "execution": {
                "noTestsAction": "error"
            },
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}